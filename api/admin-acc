import fs from "fs";
import path from "path";

export default function handler(req,res){

const filePath=
path.join(
process.cwd(),
"data",
"deposits.json"
);

let deposits=
JSON.parse(
fs.readFileSync(
filePath,
"utf8"
)
);

const {depositId}=req.body;

const index=
deposits.findIndex(
x=>x.id==depositId
);

if(index<0){

return res.json({
status:false
});

}

deposits[index]
.status="success";

fs.writeFileSync(
filePath,
JSON.stringify(
deposits,
null,
2
)
);

res.json({
status:true
});

}
